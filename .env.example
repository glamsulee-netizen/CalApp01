# ============================================
# CalApp01 — Конфигурация окружения
# ============================================
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
#
# Для локальной разработки установите ENVIRONMENT=local
# Для продакшена на VPS установите ENVIRONMENT=production
# Остальные переменные настройте соответственно.

# --- Окружение ---
ENVIRONMENT=production # local | production

# --- База данных ---
# Для local: оставьте значения по умолчанию (контейнеры Docker)
# Для production: укажите внешнюю БД (например, облачную PostgreSQL)
DATABASE_URL=postgresql://calapp:calapp_password@postgres:5432/calapp_db
POSTGRES_USER=calapp
POSTGRES_PASSWORD=calapp_password
POSTGRES_DB=calapp_db

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Сервер ---
SERVER_PORT=3000
NODE_ENV=production # production для прода, development для локальной отладки
APP_URL=https://your-domain.com # Для local: http://localhost
CORS_ORIGIN=https://your-domain.com # Для local: http://localhost

# --- SMTP (основной — Brevo) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-email@example.com
SMTP_PASSWORD=your-brevo-api-key
SMTP_FROM=noreply@your-domain.com
SMTP_DAILY_LIMIT=300

# --- SMTP (резервный — Gmail) ---
SMTP_BACKUP_HOST=smtp.gmail.com
SMTP_BACKUP_PORT=587
SMTP_BACKUP_USER=your-gmail@gmail.com
SMTP_BACKUP_PASSWORD=your-gmail-app-password
SMTP_BACKUP_FROM=your-gmail@gmail.com
SMTP_BACKUP_DAILY_LIMIT=500

# --- Web Push (VAPID) ---
# Сгенерировать ключи: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@your-domain.com

# --- Админ ---
ADMIN_EMAIL=admin@your-domain.com
ADMIN_DEFAULT_PASSWORD=
# Оставьте пустым — при первом входе система попросит задать пароль

# --- Настройки платформы ---
REGISTRATION_OPEN=true
DEFAULT_CALENDAR_START_HOUR=8
DEFAULT_CALENDAR_END_HOUR=22
DEFAULT_SLOT_DURATION=60
